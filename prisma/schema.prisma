// Schema para Sistema de Correlación Misional
// Compatible con SQLite local (desarrollo) y Turso libSQL (producción)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Zonas de la ciudad (e.g. Norte, Sur, Centro, Este, Oeste)
model Zone {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  areas       Area[]
}

// Área misional dentro de una zona
model Area {
  id              String            @id @default(cuid())
  name            String
  zoneId          String
  zone            Zone              @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  companionships  Companionship[]
  investigators   Investigator[]
  goals           Goal[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

// Compañía misional (uno o dos elders/hermanas asignados a un área)
model Companionship {
  id           String       @id @default(cuid())
  areaId       String
  area         Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  missionaires Missionary[]
  startDate    DateTime     @default(now())
  endDate      DateTime?
  active        Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Misionero individual
model Missionary {
  id               String         @id @default(cuid())
  firstName        String
  lastName         String
  fullName         String
  type             MissionaryType // ELDER o HERMANA
  role             MissionaryRole // LIDER, SENIOR, JUNIOR
  companionshipId  String
  companionship    Companionship  @relation(fields: [companionshipId], references: [id], onDelete: Cascade)
  phone            String?
  email            String?
  arrivalDate      DateTime?
  releaseDate      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum MissionaryType {
  ELDER
  HERMANA
  PAREJA
}

enum MissionaryRole {
  LIDER
  SENIOR
  JUNIOR
}

// Investigador (persona siendo enseñada)
model Investigator {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  fullName          String
  phone             String?
  address           String?
  areaId            String
  area              Area               @relation(fields: [areaId], references: [id], onDelete: Cascade)
  status            InvestigatorStatus
  source            String?            // Referencia de miembro, contacto calle, etc.
  referredBy        String?            // Nombre del miembro que refirió
  baptismDate       DateTime?
  baptismGoalDate   DateTime?
  lessonsReceived   Int                @default(0)
  churchAttendance  Int                @default(0) // veces que ha asistido
  lastVisitDate     DateTime?
  notes             String?
  progress          TeachingProgress[]
  familyMembers     FamilyMember[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum InvestigatorStatus {
  NUEVO
  EN_PROGRESO
  FECHA_BAUTISMO
  BAUTIZADO
  INACTIVO
}

// Progreso de lecciones (las 5 lecciones misionales estándar)
model TeachingProgress {
  id              String    @id @default(cuid())
  investigatorId  String
  investigator    Investigator @relation(fields: [investigatorId], references: [id], onDelete: Cascade)
  lessonNumber    Int       // 1-5
  lessonTitle     String
  completed       Boolean   @default(false)
  completedDate   DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Reunión de correlación semanal
model CorrelationMeeting {
  id           String         @id @default(cuid())
  areaId       String?        // null = correlación general de zona
  meetingDate  DateTime
  leader       String         // líder misional de barrio
  attendees    String?        // asistentes (texto libre)
  vision       String?        // visión y enfoque de la semana
  priorities   String?        // prioridades
  notes        String?        // notas generales
  commitments  String?        // compromisos
  agendaItems  AgendaItem[]
  aiAnalysis   AIAnalysis?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// Items de agenda por cada reunión de correlación
model AgendaItem {
  id               String            @id @default(cuid())
  meetingId        String
  meeting          CorrelationMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  investigatorId   String?
  topic            String
  discussion       String?
  action           String?           // acción a tomar
  responsible      String?           // responsable
  dueDate          DateTime?
  status           AgendaItemStatus  @default(PENDIENTE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

enum AgendaItemStatus {
  PENDIENTE
  EN_PROGRESO
  COMPLETADO
}

// Metas misionales (mensuales/trimestrales por área)
model Goal {
  id            String    @id @default(cuid())
  areaId        String
  area          Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  period        String    // YYYY-MM o YYYY-Q#
  goalType      GoalType
  target        Int
  actual        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum GoalType {
  BAUTISMOS
  LECCIONES
  INVESTIGADORES_NUEVOS
  ASISTENCIA_IGLESIA
  REFERENCIAS
}

// Miembro fellowshipping (acompañante)
model Fellowshipper {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  areaId        String?
  assignedTo    String?    // nombre del investigador
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ========================================
// Modelos para análisis con IA
// ========================================

// Configuración de IA (singleton — un solo registro con id="default")
model AISettings {
  id              String   @id @default("default")
  enabled         Boolean  @default(true)
  provider        String   @default("zai")          // "zai" o "gemini" (futuro)
  apiKey           String?                            // opcional: API key propia
  customSystemPrompt String?                          // prompt del usuario (opcional)
  language         String   @default("es")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Análisis con IA de una reunión de correlación
model AIAnalysis {
  id                String         @id @default(cuid())
  meetingId         String         @unique
  meeting           CorrelationMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  status            AIAnalysisStatus @default(PROCESANDO) // PROCESANDO, COMPLETADO, REFINADO, CORREGIDO, ERROR
  summary           String?        // resumen estructurado en markdown
  leadershipTasks   String?        // JSON: [{ task, who, dueDate }]
  generalTasks      String?        // JSON: [{ task, who, category }]
  questions         String?        // JSON: [{ id, question, options[], answer }]
  imagePrompt       String?        // prompt usado para la imagen
  imageDataUrl      String?        // imagen generada (URL lazy o base64)
  imageDescription  String?        // descripción textual de la imagen
  rawResponse       String?        // respuesta cruda del LLM (para debug)
  error             String?        // mensaje de error si falló
  // Edits del usuario (sobreescriben la salida de la IA)
  userCorrections   String?        // JSON con la versión corregida por el usuario
  correctionNotes   String?        // notas del usuario sobre qué estaba mal
  corrections       AICorrection[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum AIAnalysisStatus {
  PROCESANDO
  COMPLETADO
  REFINADO
  CORREGIDO
  ERROR
}

// Correcciones del usuario para que la IA aprenda
model AICorrection {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    AIAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  category    String   // 'investigators' | 'tasks' | 'summary' | 'general'
  feedback    String   // qué dijo el usuario que estaba mal o qué cambiar
  createdAt   DateTime @default(now())
}

// Miembros de familia ligados a un investigador
// (para ver quiénes son miembros y quiénes no dentro de la familia)
model FamilyMember {
  id             String   @id @default(cuid())
  investigatorId String
  investigator   Investigator @relation(fields: [investigatorId], references: [id], onDelete: Cascade)
  name           String
  age            Int?
  isMember       Boolean  @default(false)
  isInvestigator Boolean  @default(false)  // true si también es investigador
  relationship   String?  // "madre", "hijo", "esposa", "papá", etc.
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

